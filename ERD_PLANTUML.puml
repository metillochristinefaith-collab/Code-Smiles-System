@startuml Code_Smiles_ERD
!define TABLENAME(x) class x << (T,#FFAAAA) >>
!define PRIMARY_KEY(x) <b>PK:</b> x
!define FOREIGN_KEY(x) <b>FK:</b> x
!define UNIQUE_KEY(x) <b>UK:</b> x

skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F0F0F0
skinparam classBorderColor #333333
skinparam arrowColor #333333
skinparam classArrowColor #333333

' ==================== CORE USERS ====================
TABLENAME(USERS) {
  {field} <b>PK:</b> id : integer
  {field} first_name : varchar
  {field} last_name : varchar
  {field} <b>UK:</b> email : varchar
  {field} phone : varchar
  {field} password : varchar
  {field} role : varchar (patient|dentist|staff|admin)
  {field} status : varchar
  {field} specialty : text
  {field} avatar_url : text
  {field} is_verified : boolean
  {field} verification_token : varchar
  {field} verification_token_expires_at : timestamp
  {field} reset_token : varchar
  {field} reset_token_expires_at : timestamp
  {field} created_at : timestamp
}

TABLENAME(DENTIST) {
  {field} <b>PK:</b> dentist_id : integer
  {field} <b>FK,UK:</b> user_id : integer
