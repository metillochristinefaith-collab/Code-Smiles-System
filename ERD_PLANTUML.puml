  {field} phone : varchar
  {field} specialization : varchar
  {field} license_number : varchar
  {field} years_experience : integer
  {field} bio : text
  {field} working_days : jsonb
  {field} start_time : time
  {field} end_time : time
  {field} status : varchar
  {field} avatar_url : text
  {field} created_at : timestamp
  {field} updated_at : timestamp
}

TABLENAME(PATIENTS) {
  {field} <b>PK:</b> patient_id : integer
  {field} <b>FK,UK:</b> user_id : integer
  {field} first_name : varchar
  {field} last_name : varchar
  {field} <b>UK:</b> email : varchar
  {field} date_of_birth : date
  {field} gender : varchar
  {field} contact_number : varchar
  {field} address : text
  {field} emergency_contact_name : varchar
  {field} emergency_contact_phone : varchar
  {field} medical_history : text
  {field} status : varchar
  {field} avatar_url : text
  {field} specialty : text
  {field} created_at : timestamp
  {field} updated_at : timestamp
}

TABLENAME(STAFF) {
  {field} <b>PK:</b> staff_id : integer
  {field} <b>FK,UK:</b> user_id : integer
